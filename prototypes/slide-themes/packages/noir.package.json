          },
          "weight": 800,
          "lineHeight": 1.04
        }
      },
      "large": {
        "text": {
          "fontFamily": {
            "token": "fonts.heading"
          },
          "fontSizePt": 52,
          "color": {
            "token": "colors.canvas.text"
          },
          "weight": 800,
          "lineHeight": 0.98
        }
      }
