      "visibility": "default",
      "chrome": "default",
      "id": "ring",
      "component": "shape",
      "layout": {
        "frame": {
          "x": 68,
          "y": -12,
          "w": 38,
          "h": 54
        },
        "zIndex": 0
      },
      "style": {
        "fill": {
          "type": "solid",
          "color": "transparent"
        },
        "stroke": {
          "color": "#c9a24a",
          "widthPt": 1.2
        },
        "radius": {
          "allPt": 999
