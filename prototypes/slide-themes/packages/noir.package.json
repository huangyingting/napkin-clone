      "small": {
        "text": {
          "fontFamily": {
            "token": "fonts.body"
          },
          "fontSizePt": 12,
          "color": {
            "token": "colors.surface.mutedText"
          },
          "weight": 400,
          "lineHeight": 1.35
        }
      }
