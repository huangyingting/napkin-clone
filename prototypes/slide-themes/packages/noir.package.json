      "default": {
        "fill": {
          "type": "solid",
          "color": {
            "token": "colors.accent.fill"
          }
        },
        "text": {
          "fontFamily": {
            "token": "fonts.body"
          },
          "fontSizePt": 11,
          "color": {
            "token": "colors.surface.text"
          }
        }
      }
