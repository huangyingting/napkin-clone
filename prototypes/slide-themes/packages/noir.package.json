          "color": {
            "token": "colors.canvas.mutedText"
          },
          "weight": 400,
          "lineHeight": 1.36
        }
      }
    },
    "text.body": {
      "default": {
        "text": {
          "fontFamily": {
            "token": "fonts.body"
          },
          "fontSizePt": 15,
          "color": {
