{
  "schemaVersion": 1,
  "id": "noir",
  "version": "1.0.0",
  "name": "Luxe Maroon Magazine",
  "tagline": "Premium maroon and gold portfolio or brand decks.",
  "tokens": {
    "colors": {
      "canvas": {
        "fill": "#3a0d12",
        "text": "#f6ece2",
        "mutedText": "#a07b76"
      },
      "surface": {
        "fill": "#f6ece2",
        "text": "#f6ece2",
        "mutedText": "#a07b76",
        "border": "#6a1f28"
      },
      "accent": {
        "fill": "#c9a24a",
        "text": "#3a0d12"
      }
    },
    "fonts": {
      "heading": "'Source Serif 4', 'Noto Sans SC', serif",
      "body": "Inter, 'Noto Sans SC', system-ui, sans-serif"
    },
    "radii": {
      "card": 10,
      "pill": 999
    }
  },
  "styles": {
    "slide.cover": {
      "default": {
        "slide": {
          "background": {
            "type": "radialGradient",
            "inner": "#5a1820",
            "outer": "#3a0d12",
            "cx": 70,
            "cy": 0,
            "rx": 95,
            "ry": 95
          },
          "chrome": "minimal",
          "decoration": "expressive"
        }
      }
    },
    "slide.content": {
      "default": {
        "slide": {
          "background": {
            "type": "solid",
            "color": {
              "token": "colors.canvas.fill"
            }
          },
          "chrome": "default",
          "decoration": "default"
        }
      }
    },
    "slide.section": {
      "default": {
        "slide": {
          "background": {
            "type": "linearGradient",
            "from": "#3a0d12",
            "to": "#f6ece2",
            "angle": 135
