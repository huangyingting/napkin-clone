          "alternateRowFill": {
            "type": "solid",
            "color": {
              "token": "colors.canvas.fill"
            }
          },
          "border": {
            "color": {
              "token": "colors.surface.border"
            },
            "widthPt": 1
          },
          "text": {
            "fontFamily": {
              "token": "fonts.body"
            },
            "fontSizePt": 10.5,
            "color": {
              "token": "colors.surface.text"
            }
          },
          "headerText": {
            "fontFamily": {
              "token": "fonts.body"
            },
            "fontSizePt": 10.5,
            "color": {
              "token": "colors.accent.text"
            },
            "weight": 700
          }
        }
      }
