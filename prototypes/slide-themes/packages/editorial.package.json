      "role": "themeDecoration",
      "visibility": "default",
      "chrome": "default",
      "id": "accentFrame",
      "component": "shape",
      "layout": {
        "frame": {
          "x": 72,
          "y": 62,
          "w": 18,
          "h": 22
        },
        "zIndex": 0
      },
      "style": {
        "fill": {
          "type": "solid",
          "color": "transparent"
        },
        "stroke": {
          "color": "#ddd3bd",
