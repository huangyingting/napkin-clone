{
  "schemaVersion": 1,
  "id": "editorial",
  "version": "1.0.0",
  "name": "Editorial Serif Luxe",
  "tagline": "Cream, cobalt, and gold editorial storytelling decks.",
  "tokens": {
    "colors": {
      "canvas": {
        "fill": "#f3ede1",
        "text": "#191510",
        "mutedText": "#8c826d"
      },
      "surface": {
        "fill": "#fffaf0",
        "text": "#191510",
        "mutedText": "#8c826d",
        "border": "#ddd3bd"
      },
      "accent": {
        "fill": "#2f3d8f",
        "text": "#ffffff"
      }
    },
    "fonts": {
      "heading": "'Source Serif 4', 'Noto Sans SC', serif",
      "body": "Inter, 'Noto Sans SC', system-ui, sans-serif"
    },
    "radii": {
      "card": 8,
      "pill": 999
    }
  },
  "styles": {
    "slide.cover": {
      "default": {
        "slide": {
          "background": {
            "type": "solid",
            "color": "#f3ede1"
          },
          "chrome": "minimal",
          "decoration": "expressive"
        }
      }
    },
    "slide.content": {
      "default": {
        "slide": {
          "background": {
            "type": "solid",
            "color": {
              "token": "colors.canvas.fill"
            }
          },
          "chrome": "default",
          "decoration": "default"
        }
      }
    },
    "slide.section": {
      "default": {
        "slide": {
          "background": {
            "type": "linearGradient",
            "from": "#f3ede1",
            "to": "#fffaf0",
            "angle": 135
          },
          "chrome": "minimal",
          "decoration": "expressive"
        }
      }
    },
    "text.title": {
      "default": {
        "text": {
          "fontFamily": {
