    "media.hero": {
      "default": {
        "fill": {
          "type": "solid",
          "color": {
            "token": "colors.surface.fill"
          }
        },
        "image": {
          "fit": "cover",
          "radiusPct": 3
        },
        "radius": {
          "allPt": 8
        }
      }
    },
    "media.inline": {
      "default": {
        "fill": {
          "type": "solid",
          "color": {
            "token": "colors.surface.fill"
          }
