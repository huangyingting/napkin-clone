      "id": "ring",
      "component": "shape",
      "layout": {
        "frame": {
          "x": 68,
          "y": -12,
          "w": 38,
          "h": 54
        },
        "zIndex": 0
      },
      "style": {
        "fill": {
          "type": "solid",
          "color": "transparent"
        },
        "stroke": {
          "color": "#2f3d8f",
          "widthPt": 1.2
        },
        "radius": {
          "allPt": 999
        },
        "opacity": 0.42
