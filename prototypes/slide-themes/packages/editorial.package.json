    "text.body": {
      "default": {
        "text": {
          "fontFamily": {
            "token": "fonts.body"
          },
          "fontSizePt": 15,
          "color": {
            "token": "colors.surface.text"
          },
          "weight": 400,
          "lineHeight": 1.45
