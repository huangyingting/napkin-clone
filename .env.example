# Copy to .env and adjust for your environment.

# Database engine selection: "sqlite" (default, zero-setup local dev/test) or
# "postgres" (production). When unset, the app and Prisma CLI default to SQLite.
DB_PROVIDER="sqlite"

# Connection string used by Prisma and the app.
# - SQLite (default): a local file is used automatically when DATABASE_URL is
#   unset (file:./prisma/dev.db). Override only if you want a different path:
DATABASE_URL="file:./prisma/dev.db"
# - Postgres (production): set DB_PROVIDER=postgres and a postgresql:// URL, e.g.
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/textiq?schema=public"

# Auth.js (NextAuth v5) — session encryption secret (required).
# Generate with: openssl rand -base64 32  (or `npx auth secret`)
AUTH_SECRET="generate-a-strong-random-secret"

# Canonical app origin used to build OAuth redirect URIs. The dev server binds
# to 0.0.0.0, so without this Auth.js may derive a redirect_uri of
# http://0.0.0.0:4000/... which Google rejects (raw IPs are not allowed). Set
# this to the host you actually open in the browser so the redirect_uri matches
# the one registered in the Google console (e.g. http://localhost:4000).
AUTH_URL="http://localhost:4000"

# Google OAuth (Auth.js) — create an OAuth client at
# https://console.cloud.google.com/apis/credentials and add the authorized
# redirect URI <origin>/api/auth/callback/google (e.g.
# http://localhost:4000/api/auth/callback/google). The Google sign-in button is
# only enabled when both values are set.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Azure OpenAI — powers POST /api/generate (text -> visual schemas).
# Endpoint of your Azure OpenAI resource (no trailing slash needed):
AZURE_OPENAI_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com"
AZURE_OPENAI_API_KEY=""
# Deployment name to call (defaults to gpt-5.5 when unset):
AZURE_OPENAI_DEPLOYMENT="gpt-5.5"
# REST api-version (defaults to the latest stable GA version when unset):
AZURE_OPENAI_API_VERSION="2024-10-21"

# AI deck generation (POST /api/generate-deck) — feature flag, default OFF.
# When unset/falsy the route returns 404; set to a truthy value (1/true/yes/on)
# to enable it (still gated by Azure config, quota, and credit metering). Read
# at call time via isAiDeckGenEnabled(), so it can be toggled without a restart.
# AI_DECK_GEN_ENABLED="1"

# Client-readable mirror of AI_DECK_GEN_ENABLED used to gate the slide-editor
# "Generate with AI" entry point (#268). AI_DECK_GEN_ENABLED is server-only, so
# the client bundle can't read it; this public (NEXT_PUBLIC_*) var is statically
# inlined at build time to show/hide the UI affordance. The server flag remains
# the security boundary — set BOTH to enable the feature end-to-end.
# NEXT_PUBLIC_AI_DECK_GEN_ENABLED="1"

# Optional generation quota tuning (sensible defaults are applied when unset).
# Lifetime free generations for an anonymous visitor (signed cookie):
# ANON_GENERATION_LIMIT="5"
# Authenticated per-user rate limit and window (milliseconds):
# USER_GENERATION_RATE_LIMIT="30"
# USER_GENERATION_RATE_WINDOW_MS="60000"

# Real-time collaboration (US-019) — by default the app server (`npm run dev` /
# `npm start`, via `server.mjs`) hosts the Yjs websocket on the SAME port at the
# `/collab` path, so the browser derives the URL from the page origin and
# collaboration works automatically through a single forwarded port (e.g. VS Code
# port forwarding) with no extra config. Set COLLAB_INLINE=0 to disable the
# inline socket and instead run the standalone server (`npm run collab`, default
# port 1234); then point clients at it with NEXT_PUBLIC_COLLAB_WS_URL. Must be a
# public (NEXT_PUBLIC_*) var so the client bundle can read it.
# COLLAB_INLINE=1
# NEXT_PUBLIC_COLLAB_WS_URL="ws://localhost:1234"
# COLLAB_PORT=1234

# Public app URL — used for building share links. Set to your deployed URL in
# production (e.g., https://textiq.example.com) or leave unset to default to
# http://localhost:4000 in local development.
# NEXT_PUBLIC_APP_URL="http://localhost:4000"
