{
  "name": "textiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "collab": "node scripts/collab-server.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\" && node --test \"scripts/**/*.test.mjs\"",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:schema:sqlite": "node scripts/gen-sqlite-schema.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma generate && prisma db push --force-reset && prisma db seed",
    "audit:schema": "node --import tsx src/scripts/audit-persisted-schema.ts",
    "migrate:schema": "node --import tsx src/scripts/migrate-persisted-schema.ts",
    "migrate:brand-assets": "node --import tsx src/scripts/migrate-brand-assets.ts"
  },
  "dependencies": {
    "@lexical/history": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@lexical/yjs": "^0.45.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lexical": "^0.45.0",
    "lib0": "^0.2.117",
    "lucide-react": "^1.20.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "ws": "^8.21.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@lexical/headless": "^0.45.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
