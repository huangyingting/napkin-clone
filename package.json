{
  "name": "textiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "collab": "node scripts/collab-server.mjs",
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "dev:setup": "node scripts/dev-setup.mjs",
    "dev:worktree": "node scripts/dev-worktree.mjs",
    "ci:local": "node scripts/ci-local.mjs",
    "qa:browser": "node scripts/browser-qa.mjs",
    "lint": "npm run design-system:check && npm run action-ports:check && npm run next-build-constraints:check && npm run client-boundary:check && npm run import-graph:check && npm run e2e-governance:check && eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "npm run test:line-coverage && npm run test:coverage-map",
    "test:unit": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:scripts": "node --test \"scripts/**/*.test.mjs\"",
    "test:line-coverage": "node scripts/check-line-coverage.mjs",
    "test:subsystem": "node scripts/test-subsystem.mjs",
    "test:coverage-map": "node scripts/test-subsystem.mjs --check",
    "test:auth": "npm run test:subsystem -- auth",
    "test:collab": "npm run test:subsystem -- collaboration",
    "test:documents": "npm run test:subsystem -- documents",
    "test:editor": "npm run test:subsystem -- editor",
    "test:import": "npm run test:subsystem -- import",
    "test:presentation": "npm run test:subsystem -- presentation",
    "test:public-render": "npm run test:subsystem -- public-render",
    "test:security": "npm run test:subsystem -- security",
    "test:visual": "npm run test:subsystem -- visual",
    "test:operations": "npm run test:subsystem -- operations",
    "test:e2e": "playwright test",
    "test:e2e:profile": "E2E_PROFILE=1 playwright test",
    "test:e2e:profile:self-contained": "node scripts/e2e-profile.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "production-install:smoke": "NODE_ENV=production DB_PROVIDER=sqlite DATABASE_URL=\"file:./prisma/dev.db\" AUTH_SECRET=ci-placeholder node scripts/production-install-smoke.mjs",
    "client-boundary:check": "node scripts/check-client-boundary.mjs",
    "import-graph:check": "node scripts/check-import-graph.mjs",
    "docs:check": "node --import tsx --test src/app/api/api-route-security-matrix.test.ts && node scripts/check-docs-source-inventory.mjs && node scripts/check-docs-links.mjs && prettier --check \"docs/**/*.md\"",
    "design-system:check": "node scripts/check-design-system.mjs",
    "action-ports:check": "node scripts/check-action-ports.mjs",
    "e2e-governance:check": "node scripts/check-e2e-governance.mjs",
    "next-build-constraints:check": "node scripts/check-next-build-constraints.mjs",
    "postinstall": "npm run db:generate",
    "db:generate": "node scripts/gen-sqlite-schema.mjs --if-sqlite && prisma generate",
    "db:schema:sqlite": "node scripts/gen-sqlite-schema.mjs",
    "db:schema:check": "node scripts/gen-sqlite-schema.mjs --check",
    "db:push": "node scripts/gen-sqlite-schema.mjs --if-sqlite && prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:e2e": "node --import tsx prisma/seed-e2e.ts",
    "db:reset": "node scripts/gen-sqlite-schema.mjs --if-sqlite && prisma generate && prisma db push --force-reset && prisma db seed",
    "audit:schema": "node --import tsx src/scripts/audit-persisted-schema.ts"
  },
  "dependencies": {
    "@lexical/history": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@lexical/yjs": "^0.45.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lexical": "^0.45.0",
    "lib0": "^0.2.117",
    "lucide-react": "^1.20.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "ws": "^8.21.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@lexical/headless": "^0.45.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
