# === Next.js / Node app ===
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# E2E deterministic profile artifacts (Epic #517) — generated by db:seed:e2e
/storage/
/e2e/.e2e-fixture.json

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (regenerated via postinstall: prisma generate)
/src/generated/

# prisma local SQLite database files (created by db:migrate/db:reset)
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm

# === Ralph working files (generated during runs) ===
prd.json
progress.txt
.last-branch

# Archive is optional to commit
# archive/

# OS files
.DS_Store

# Claude
.claude/

/src/generated/prisma
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/

# Repo-local test scratch files
.tmp/test-fixtures/

# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Squad/Ralph runtime working files (machine-local, not for VCS)
watch.log
.squad/ralph-circuit-breaker.json
