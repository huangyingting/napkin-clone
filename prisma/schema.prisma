// Prisma schema for the TextIQ app.
// The datasource URL is supplied via prisma.config.ts (env DATABASE_URL).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  passwordHash      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // Monetization: tier + credit balance
  plan              String    @default("free")
  creditBalance     Int       @default(0)
  creditPeriodStart DateTime?

  documents       Document[]        @relation("DocumentOwner")
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  comments        Comment[]
  tags            Tag[]
  brands          Brand[]           @relation("BrandOwner")
  subscription    Subscription?
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  documents   Document[]
  inviteLinks InviteLink[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("VIEWER")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Document {
  id          String   @id @default(cuid())
  title       String   @default("Untitled")
  content     String   @default("")
  contentJson Json?
  deckJson    Json?
  ownerId     String
  workspaceId String?
  shareId     String?  @unique
  slug        String?  @unique
  isShared    Boolean  @default(false)
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  owner     User       @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  visuals   Visual[]
  comments  Comment[]
  tags      Tag[]      @relation("DocumentTags")

  @@index([ownerId])
  @@index([workspaceId])
  @@index([shareId])
  @@index([deletedAt])
}

// Flat, owner-scoped tags for organizing documents. Tag names (and slugs) are
// unique per owner; the many-to-many relation to Document uses an implicit
// join table (`_DocumentTags`). The slug derives from slugify(name) (US-027).
model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents Document[] @relation("DocumentTags")

  @@unique([ownerId, name])
  @@unique([ownerId, slug])
  @@index([ownerId])
}

model Visual {
  id            String   @id @default(cuid())
  documentId    String
  anchorBlockId String?
  orderIndex    Int      @default(0)
  type          String
  title         String?
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  document  Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  revisions VisualRevision[]

  @@index([documentId])
}

model VisualRevision {
  id        String   @id @default(cuid())
  visualId  String
  data      Json
  type      String
  title     String?
  createdAt DateTime @default(now())

  visual Visual @relation(fields: [visualId], references: [id], onDelete: Cascade)

  @@index([visualId])
}

model Comment {
  id           String   @id @default(cuid())
  documentId   String
  authorId     String
  body         String
  resolved     Boolean  @default(false)
  parentId     String?
  // Optional anchor tying a top-level comment to text or a visual element.
  // anchorType: null (whole document) | "text" | "visual".
  anchorType   String?
  anchorText   String?
  anchorNodeId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([documentId])
  @@index([authorId])
  @@index([parentId])
}

model InviteLink {
  id          String   @id @default(cuid())
  workspaceId String
  token       String   @unique
  role        String   @default("VIEWER")
  isRevoked   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([token])
}

// Shared, DB-backed fixed-window rate-limit state for the AI generation
// endpoint (US-018). One row per subject (an authenticated user id); the row
// holds the current window's hit count and its reset instant. Persisting this
// instead of a per-instance in-memory Map lets the limit hold across instances
// in production. The window is first-request-anchored (resetAt = first hit +
// window), preserving the existing in-memory semantics.
model RateLimitHit {
  subject   String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}

// A saved brand style owned by one user (US-007 — Brand Studio).
// All color fields are optional so a brand can hold a partial palette
// and defaults fall through to the visual DEFAULT_STYLE. `logoUrl` is
// the public URL of an uploaded logo asset. `fontFamily` overrides the
// visual's font when the brand is applied.
model Brand {
  id           String   @id @default(cuid())
  name         String
  ownerId      String
  // Color fields (all optional — null means "keep visual default")
  palette      Json?
  background   String?
  nodeFill     String?
  nodeStroke   String?
  nodeText     String?
  edgeColor    String?
  // Typography
  fontFamily   String?
  // Font asset (durable data-URL for uploaded custom fonts, mirrors logoUrl)
  fontDataUrl  String?
  // Asset (logo stored as a data-URL or public path, max 2 MB)
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner User @relation("BrandOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// Monetization: active subscription for a user.
// One row per user — upserted on plan changes. Stores the billing period,
// the Stripe customer and subscription ids (kept separate — a customer can
// outlive any single subscription), and cancellation intent.
model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 String   @default("free")
  status               String   @default("active")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
